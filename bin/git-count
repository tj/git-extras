#!/usr/bin/env bash

if test "$1" = "--all"; then
  git shortlog -n -s | awk '{print substr($0,index($0,$2)) " (" $1 ")"}'
  echo
fi

# Bug fix: HEAD^ is the first parent of current commit, so the count excluded the current commit.
# The intended behavior is to count all commits reachable from HEAD including HEAD itself.
echo total "$(git rev-list --count HEAD)"
